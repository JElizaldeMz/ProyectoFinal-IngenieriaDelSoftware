# ============================================================
# Festival Internacional de las Luciérnagas 2026 — MEC Solutions
# ARCHIVO DE EJEMPLO — copiar como .env y rellenar los valores
# ============================================================

# ── Django ──────────────────────────────────────────────────
# Genera una clave segura con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esta-clave-por-una-segura

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Base de datos ────────────────────────────────────────────
# SQLite para desarrollo (no cambiar)
DATABASE_URL=sqlite:///db.sqlite3

# ── Correo electrónico ───────────────────────────────────────
# DESARROLLO: imprime los correos en la terminal, no necesita credenciales
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# PRODUCCIÓN: descomenta y rellena con tu cuenta Gmail
# Pasos para obtener la contraseña de aplicación:
#   1. Activa verificación en 2 pasos en myaccount.google.com
#   2. Ve a myaccount.google.com/apppasswords
#   3. Crea una contraseña con nombre "Django Festival"
#   4. Copia los 16 caracteres aquí (con espacios)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tucorreo@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# DEFAULT_FROM_EMAIL=Festival Luciérnagas <tucorreo@gmail.com>

DEFAULT_FROM_EMAIL=MEC Solutions <noreply@mecsolutions.com>
